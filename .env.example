# ─────────────────────────────────────────────────────────────────────────────
# OnTimeCRM — Environment Variables
# Copy this file to .env and fill in the values before running docker-compose
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_WITH_A_STRONG_PASSWORD
POSTGRES_DB=ontimecrm

# JWT — must be at least 32 characters long
JWT_KEY=REPLACE_WITH_A_RANDOM_SECRET_MINIMUM_32_CHARS

# Admin bootstrap account (created on first startup if no companies exist)
ADMIN_EMAIL=admin@ontimecrm.io
ADMIN_PASSWORD=REPLACE_WITH_A_STRONG_ADMIN_PASSWORD
